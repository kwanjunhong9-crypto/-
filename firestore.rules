rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isClassOwner(classData) {
      return isAuthenticated() && request.auth.uid == classData.teacherId;
    }

    function isValidClass(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.teacherId == request.auth.uid &&
             data.students is list &&
             data.createdAt is string;
    }

    match /classes/{classId} {
      // Allow anyone to read class data for student login and viewing
      allow read: if true;
      allow create: if isAuthenticated() && isValidClass(request.resource.data);
      // Allow students to update their own data (coins, points, pets)
      allow update: if true; 
      allow delete: if isAuthenticated() && isClassOwner(resource.data);
    }

    match /studentPasswords/{password} {
      // Anyone can read a specific password doc to log in
      allow read: if true;
      // Allow creation/update of password mappings
      allow create, update, delete: if true;
    }

    match /posts/{postId} {
      // Allow students to see class posts
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /homeworks/{homeworkId} {
      // Allow students to see homework
      allow read: if true;
      // Allow students to mark homework as completed
      allow update: if true;
      // Only teachers can create/delete homework
      allow create, delete: if isAuthenticated();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
